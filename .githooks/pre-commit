#!/bin/sh
# pre-commit: 빠른 피드백 게이트 — 린트 + 포맷 검사(mise 태스크).
# 툴체인이 아직 스캐폴딩되지 않았으면(docs-only 단계) 조용히 건너뛴다.
# 강제 검증(유닛 테스트 포함)은 pre-push가 담당한다.
set -e

echo "[pre-commit] 린트/포맷 검사"

if [ -f .mise.toml ] && [ -f package.json ] && command -v mise >/dev/null 2>&1; then
  mise run lint
  mise run fmt-check
else
  echo "[pre-commit] 툴체인 미설정 — 건너뜀(스캐폴딩 후 자동 활성화)"
fi

exit 0
