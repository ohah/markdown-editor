#!/bin/sh
# pre-commit: 빠른 피드백 게이트 — 린트 + 포맷 검사.
# 툴체인이 아직 스캐폴딩되지 않았으면(docs-only 단계) 조용히 건너뛴다.
# 강제 검증(유닛 테스트 포함)은 pre-push가 담당한다.
set -e

echo "[pre-commit] 린트/포맷 검사"
RAN=0

if [ -f package.json ] && command -v bun >/dev/null 2>&1; then
  bun run lint
  bun run fmt:check
  RAN=1
fi

if [ -f Cargo.toml ] && command -v cargo >/dev/null 2>&1; then
  cargo fmt --check
  RAN=1
fi

if [ "$RAN" = 0 ]; then
  echo "[pre-commit] 툴체인 미설정 — 건너뜀(스캐폴딩 후 자동 활성화)"
fi

exit 0
